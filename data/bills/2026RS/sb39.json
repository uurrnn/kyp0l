  "session": "2026RS",
  "identifier": "SB 39",
  "title": "AN ACT relating to fish and wildlife and declaring an emergency.",
  "abstract": "Amend KRS 150.170 to exempt a bona fide private landowner from any fishing restrictions imposed in KRS Chapter 150 or the administrative regulations promulgated thereunder relating to creel, possession, size, or method of take; allow a private landowner to extend the same rights and privileges relating to fishing in lakes or ponds located on the landowner's property to any person in written or electronic form; allow the stocking of certain largemouth bass in private lakes and ponds without restriction; exempt a bona fide private landowner from any lake or pond stocking restrictions except with regard to prohibitions on the stocking of invasive fish.",
  "classification": [
    "bill"
  ],
