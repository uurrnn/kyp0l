---
import Layout from "~/layouts/Layout.astro";
import { getAllTopics } from "~/lib/topics";

const topics = getAllTopics();
const base = import.meta.env.BASE_URL;
const totalBills = topics.reduce((sum, t) => sum + t.count, 0);
---

<Layout title="Topics — kyp0l" description="Curated landing pages for major Kentucky policy areas, pulling bills, sponsors, and committees together.">
  <h1>Topics</h1>
  <p style="color: var(--fg-muted); margin-bottom: var(--space-5);">
    Twelve curated policy areas covering {totalBills.toLocaleString()} bills in the active session.
    Each page surfaces the hottest bills, recent action, top sponsors, and related committees for that area.
    For the full subject list (including procedural tags), see <a href={`${base}bills`}>/bills</a>.
  </p>

  <div class="topics-grid">
    {topics.map((t) => (
      <a class="topic-card" href={`${base}topic/${t.slug}`}>
        <div class="topic-card-name">{t.subject}</div>
        <div class="topic-card-meta">{t.count.toLocaleString()} bill{t.count === 1 ? "" : "s"}</div>
      </a>
    ))}
  </div>
</Layout>

<style>
  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-3);
  }
  .topic-card {
    display: block;
    padding: var(--space-4);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.12s;
  }
  .topic-card:hover { border-color: var(--accent); text-decoration: none; }
  .topic-card-name {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: var(--space-2);
  }
  .topic-card-meta {
    font-size: var(--text-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
  }
</style>
