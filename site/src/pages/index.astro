---
import Layout from "~/layouts/Layout.astro";
import {
  getMeetings,
  getBodies,
  getBills,
  formatMeetingDate,
  getBodyById,
  billStatusTone,
  getSessionStatus,
} from "~/lib/data";
import { FEATURED_SUBJECTS } from "~/lib/featured-subjects";
import { getHotBills } from "~/lib/heat";
import { slugifySubject } from "~/lib/topics";

const meetings = getMeetings();
const bodies = getBodies();
const bills = getBills();
const hotBills = getHotBills(8);
const sessionStatus = getSessionStatus();
const base = import.meta.env.BASE_URL;
const recess = !sessionStatus.inSession;

// ----------------------------------------------------------- masthead numbers

const now = new Date();
const sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000)
  .toISOString()
  .slice(0, 10);
const todayISO = now.toISOString().slice(0, 10);

const billsActiveThisWeek = bills.filter((b) => b.last_action_date >= sevenDaysAgo).length;
// "Awaiting governor" = passed both chambers but not yet signed/vetoed/became law.
// billStatusTone === "passed" captures this exactly, since the helper promotes a
// bill to "law" once any became-law action exists (some bills are delivered to
// the Secretary of State without an explicit executive-signature classification).
const billsAwaitingGovernor = bills.filter((b) => billStatusTone(b) === "passed").length;

const masthead = [
  { num: bills.length, label: "Bills tracked", href: `${base}bills` },
  { num: bodies.length, label: "Bodies", href: `${base}#bodies` },
  { num: meetings.length, label: "Meetings indexed", href: `${base}#meetings` },
  { num: billsActiveThisWeek, label: "Active this week", href: `${base}bills?recent=7` },
  { num: billsAwaitingGovernor, label: "Awaiting governor", href: `${base}bills?status=passed` },
];

// ----------------------------------------------------------- this-week columns
//
// During session recess the strict "last 7 days" predicate returns an empty
// list, which is honest but a dead-feeling dashboard. We render the predicate
// match if there is any, otherwise fall back to the latest-N regardless of
// date and label the column "(recent)" instead of "(this week)".

interface BillTouch { bill: typeof bills[number]; date: string; }
function latestActionMatching(b: typeof bills[number], pred: (cls: string[]) => boolean): string | null {
  for (let i = b.actions.length - 1; i >= 0; i--) {
    if (pred(b.actions[i].classification)) return b.actions[i].date;
  }
  return null;
}

const referrals: BillTouch[] = [];
const floorActions: BillTouch[] = [];
for (const b of bills) {
  const ref = latestActionMatching(b, (cls) => cls.includes("referral-committee"));
  if (ref) referrals.push({ bill: b, date: ref });
  const floor = latestActionMatching(b, (cls) =>
    cls.some((c) => c === "passage" || c === "failure" || c === "executive-veto" || c === "veto-override-passage" || c === "executive-signature" || c === "became-law"),
  );
  if (floor) floorActions.push({ bill: b, date: floor });
}
referrals.sort((a, b) => b.date.localeCompare(a.date));
floorActions.sort((a, b) => b.date.localeCompare(a.date));

const recentReferrals = referrals.filter((r) => r.date >= sevenDaysAgo);
const recentFloor = floorActions.filter((r) => r.date >= sevenDaysAgo);

const referralsToShow = recentReferrals.length > 0 ? recentReferrals.slice(0, 5) : referrals.slice(0, 5);
const referralsLabel = recentReferrals.length > 0 ? "Committee referrals · this week" : "Committee referrals · recent";

const floorToShow = recentFloor.length > 0 ? recentFloor.slice(0, 5) : floorActions.slice(0, 5);
const floorLabel = recentFloor.length > 0 ? "Floor actions · this week" : "Floor actions · recent";

const upcomingMeetings = meetings
  .filter((m) => m.date >= todayISO)
  .sort((a, b) => a.date.localeCompare(b.date))
  .slice(0, 5);

// ----------------------------------------------------------- subject pulse

const subjectCounts = new Map<string, number>();
for (const b of bills) {
  for (const s of b.subjects) subjectCounts.set(s, (subjectCounts.get(s) || 0) + 1);
}
const featuredWithCounts = FEATURED_SUBJECTS
  .map((s) => ({ subject: s, count: subjectCounts.get(s) || 0 }))
  .filter((s) => s.count > 0)
  .sort((a, b) => b.count - a.count);
const totalSubjects = subjectCounts.size;

// ----------------------------------------------------------- recent activity

const recentActivity = bills.slice(0, 25);
// Split local (PrimeGov + KSBA) from KY interim (LRC) so interim committees
// have their own surface during recess instead of being buried under daily
// Metro Council meetings.
const recentLocalMeetings = meetings
  .filter((m) => m.source_type === "primegov" || m.source_type === "ksba")
  .slice(0, 10);
const recentInterimMeetings = meetings
  .filter((m) => m.source_type === "lrc-interim")
  .slice(0, 8);
// Legacy: when not in recess we still show the unified list.
const recentMeetings = meetings.slice(0, 10);
---

<Layout title="kyp0l — A standing record of state and city business" description="Searchable index of Kentucky General Assembly bills, Louisville Metro Council, and JCPS Board agendas.">
  {recess && sessionStatus.lastActionDate && (
    <div class="recess-banner" data-pagefind-ignore>
      <strong>Session recess.</strong>
      KY {sessionStatus.session ?? "General Assembly"} adjourned {sessionStatus.lastActionDate} ({Math.round(sessionStatus.daysSinceLastAction)} days ago).
      No new bill activity until next session — prefiled bills (BR series) typically begin appearing in November. Local Metro Council and JCPS Board meetings continue year-round.
    </div>
  )}

  {/* masthead numbers */}
  <div class="numbers-strip" data-pagefind-ignore>
    {masthead.map((t) => (
      <a class="tile" href={t.href}>
        <div class="tile-num">{t.num.toLocaleString()}</div>
        <div class="tile-label">{t.label}</div>
      </a>
    ))}
  </div>

  {/* today / this week strip */}
  <div class="this-week-strip" data-pagefind-ignore>
    <div class="column-card">
      <h3>{referralsLabel}</h3>
      {referralsToShow.length === 0 ? (
        <p class="empty">No committee referrals on record.</p>
      ) : (
        referralsToShow.map(({ bill, date }) => (
          <a class="item" href={`${base}bill/${bill.id}`}>
            <strong>{bill.identifier}</strong> · {bill.title.slice(0, 90)}{bill.title.length > 90 ? "…" : ""}
            <div class="meta">{date}</div>
          </a>
        ))
      )}
    </div>
    <div class="column-card">
      <h3>{floorLabel}</h3>
      {floorToShow.length === 0 ? (
        <p class="empty">No recent floor activity.</p>
      ) : (
        floorToShow.map(({ bill, date }) => {
          const tone = billStatusTone(bill);
          return (
            <a class="item" href={`${base}bill/${bill.id}`}>
              <strong>{bill.identifier}</strong> · {bill.title.slice(0, 80)}{bill.title.length > 80 ? "…" : ""}
              <div class="meta">{date} · <span class={`status-badge ${tone}`}>{bill.current_status}</span></div>
            </a>
          );
        })
      )}
    </div>
    <div class="column-card">
      <h3>Meetings ahead</h3>
      {upcomingMeetings.length === 0 ? (
        <p class="empty">No future meetings on the calendar yet.</p>
      ) : (
        upcomingMeetings.map((m) => {
          const body = getBodyById(m.body_id);
          return (
            <a class="item" href={`${base}meeting/${m.id}`}>
              <strong>{body?.name ?? m.body_id}</strong>
              <div class="meta">{formatMeetingDate(m)}</div>
            </a>
          );
        })
      )}
    </div>
  </div>

  {/* hot bills strip */}
  {hotBills.length > 0 && (
    <div class="hot-strip" data-pagefind-ignore>
      <h3>{recess ? `Most active bills · ${sessionStatus.session ?? "session"}` : "Hot right now"}</h3>
      <ol class="hot-list">
        {hotBills.map((b) => {
          const tone = billStatusTone(b);
          return (
            <li>
              <a class="hot-row" href={`${base}bill/${b.id}`}>
                <span class="hot-id">{b.identifier}</span>
                <span class="hot-title">{b.title.length > 110 ? b.title.slice(0, 110) + "…" : b.title}</span>
                <span class={`status-badge ${tone}`}>{b.current_status}</span>
                <span class="hot-date">{b.last_action_date}</span>
              </a>
            </li>
          );
        })}
      </ol>
    </div>
  )}

  {/* subject pulse */}
  {featuredWithCounts.length > 0 && (
    <div class="pulse-strip" data-pagefind-ignore>
      <h3>Subjects</h3>
      <div>
        {featuredWithCounts.map((s) => (
          <a class="subject-chip" href={`${base}topic/${slugifySubject(s.subject)}`}>
            {s.subject}<span class="count">{s.count}</span>
          </a>
        ))}
        <a class="subject-chip" href={`${base}topics`} style="font-weight: 600;">
          All topics →
        </a>
      </div>
    </div>
  )}

  {/* recent legislative activity feed + recent meetings — order swaps in recess */}
  {(() => null)()}
  {recess ? (
    <>
      {recentInterimMeetings.length > 0 && (
        <>
          <h2 class="dashboard-section-header">KY interim committee activity</h2>
          <p style="color: var(--fg-muted); margin: calc(-1 * var(--space-3)) 0 var(--space-3); font-size: var(--text-sm);">
            Where between-session policy work happens — testimony, studies, and draft bills heading into the next session.
          </p>
          <div data-pagefind-ignore>
            {recentInterimMeetings.map((m) => {
              const body = getBodyById(m.body_id);
              return (
                <a class="meeting-card" href={`${base}meeting/${m.id}`}>
                  <div class="date">{formatMeetingDate(m)}</div>
                  <div class="body-name">{body?.name ?? m.body_id}</div>
                  {m.title && m.title !== (body?.name ?? "") && <div class="title">{m.title}</div>}
                  <div class="meta">{m.items.length} items · {m.attachments.length} attachments</div>
                </a>
              );
            })}
          </div>
        </>
      )}

      <h2 id="meetings" class="dashboard-section-header">Recent Louisville meetings</h2>
      <div data-pagefind-ignore>
        {recentLocalMeetings.length === 0 ? (
          <p class="empty-state">No meetings yet — run <code>python -m scrapers --sources primegov,ksba</code>.</p>
        ) : (
          recentLocalMeetings.map((m) => {
            const body = getBodyById(m.body_id);
            return (
              <a class="meeting-card" href={`${base}meeting/${m.id}`}>
                <div class="date">{formatMeetingDate(m)}</div>
                <div class="body-name">{body?.name ?? m.body_id}</div>
                {m.title && m.title !== (body?.name ?? "") && <div class="title">{m.title}</div>}
                <div class="meta">{m.items.length} items · {m.attachments.length} attachments</div>
              </a>
            );
          })
        )}
      </div>

      <h2 class="dashboard-section-header">Latest state legislative activity ({sessionStatus.session ?? "session"})</h2>
      <div data-pagefind-ignore>
        {recentActivity.length === 0 ? (
          <p class="empty-state">No bills yet — set <code>OPENSTATES_API_KEY</code> and run <code>python -m scrapers --sources openstates</code>.</p>
        ) : (
          <table class="bills-table">
            <thead>
              <tr>
                <th class="col-id">Bill</th>
                <th class="col-title">Title</th>
                <th class="col-status">Status</th>
                <th class="col-date">Last action</th>
              </tr>
            </thead>
            <tbody>
              {recentActivity.map((b) => {
                const tone = billStatusTone(b);
                return (
                  <tr>
                    <td class="col-id"><a href={`${base}bill/${b.id}`}>{b.identifier}</a></td>
                    <td class="col-title"><a href={`${base}bill/${b.id}`}>{b.title}</a></td>
                    <td class="col-status"><span class={`status-badge ${tone}`}>{b.current_status}</span></td>
                    <td class="col-date">{b.last_action_date}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        )}
      </div>
    </>
  ) : (
    <>
      <h2 class="dashboard-section-header">Recent legislative activity</h2>
      <div data-pagefind-ignore>
        {recentActivity.length === 0 ? (
          <p class="empty-state">No bills yet — set <code>OPENSTATES_API_KEY</code> and run <code>python -m scrapers --sources openstates</code>.</p>
        ) : (
          <table class="bills-table">
            <thead>
              <tr>
                <th class="col-id">Bill</th>
                <th class="col-title">Title</th>
                <th class="col-status">Status</th>
                <th class="col-date">Last action</th>
              </tr>
            </thead>
            <tbody>
              {recentActivity.map((b) => {
                const tone = billStatusTone(b);
                return (
                  <tr>
                    <td class="col-id"><a href={`${base}bill/${b.id}`}>{b.identifier}</a></td>
                    <td class="col-title"><a href={`${base}bill/${b.id}`}>{b.title}</a></td>
                    <td class="col-status"><span class={`status-badge ${tone}`}>{b.current_status}</span></td>
                    <td class="col-date">{b.last_action_date}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        )}
      </div>

      <h2 id="meetings" class="dashboard-section-header">Recent meetings</h2>
      <div data-pagefind-ignore>
        {recentMeetings.length === 0 ? (
          <p class="empty-state">No meetings yet — run <code>python -m scrapers --sources primegov,ksba</code>.</p>
        ) : (
          recentMeetings.map((m) => {
            const body = getBodyById(m.body_id);
            return (
              <a class="meeting-card" href={`${base}meeting/${m.id}`}>
                <div class="date">{formatMeetingDate(m)}</div>
                <div class="body-name">{body?.name ?? m.body_id}</div>
                {m.title && m.title !== (body?.name ?? "") && <div class="title">{m.title}</div>}
                <div class="meta">{m.items.length} items · {m.attachments.length} attachments</div>
              </a>
            );
          })
        )}
      </div>
    </>
  )}

  {/* browse by body */}
  {bodies.length > 0 && (
    <>
      <h2 id="bodies" class="dashboard-section-header">Browse by body</h2>
      <p>
        {bodies.map((b) => (
          <a class="body-pill" href={`${base}body/${b.id}`}>{b.name}</a>
        ))}
      </p>
    </>
  )}
</Layout>
