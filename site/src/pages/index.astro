---
import Layout from "~/layouts/Layout.astro";
import { getMeetings, getBodies, formatMeetingDate, getBodyById } from "~/lib/data";

const meetings = getMeetings();
const bodies = getBodies();
const recent = meetings.slice(0, 50);
const base = import.meta.env.BASE_URL;
---

<Layout title="Louisville Local Politics" description="Searchable index of Louisville Metro and JCPS Board agendas.">
  <h1>Recent meetings</h1>
  <p>
    Tracking <strong>{bodies.length}</strong> local bodies across Louisville Metro Council
    (PrimeGov) and JCPS Board of Education (KSBA).
    <strong>{meetings.length}</strong> meetings indexed.
    Showing the {recent.length} most recent.
  </p>

  <div data-pagefind-ignore>
    {recent.length === 0 && <p class="empty-state">No meetings yet — run <code>python -m scrapers</code> to populate <code>/data/</code>.</p>}
    {recent.map((m) => {
      const body = getBodyById(m.body_id);
      return (
        <a class="meeting-card" href={`${base}meeting/${m.id}`}>
          <div class="date">{formatMeetingDate(m)}</div>
          <div class="body-name">{body?.name ?? m.body_id}</div>
          <div class="title">{m.title}</div>
          <div class="meta">{m.items.length} items · {m.attachments.length} attachments</div>
        </a>
      );
    })}
  </div>

  {bodies.length > 0 && (
    <section style="margin-top: 2rem;">
      <h2>Browse by body</h2>
      <p>
        {bodies.map((b) => (
          <a class="body-pill" href={`${base}body/${b.id}`}>{b.name}</a>
        ))}
      </p>
    </section>
  )}
</Layout>
