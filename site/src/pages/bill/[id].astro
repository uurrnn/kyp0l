---
import Layout from "~/layouts/Layout.astro";
import ChamberProgress from "~/components/ChamberProgress.astro";
import VoteCard from "~/components/VoteCard.astro";
import { getBills, getBillById, getBodyById, billStatusTone } from "~/lib/data";

export function getStaticPaths() {
  return getBills().map((b) => ({ params: { id: b.id } }));
}

const { id } = Astro.params;
const bill = getBillById(id!);
const base = import.meta.env.BASE_URL;

function chamberLabel(ch: "lower" | "upper" | null): string {
  if (ch === "lower") return "House";
  if (ch === "upper") return "Senate";
  return "";
}

const tone = bill ? billStatusTone(bill) : "pending";
const sortedVotes = bill
  ? [...bill.votes].sort((a, b) => b.date.localeCompare(a.date))
  : [];
const primarySponsors = bill ? bill.sponsors.filter((s) => s.primary) : [];
const coSponsors = bill ? bill.sponsors.filter((s) => !s.primary) : [];
const PRIMARY_VISIBLE = 8;
const visiblePrimary = primarySponsors.slice(0, PRIMARY_VISIBLE);
const hiddenPrimary = primarySponsors.slice(PRIMARY_VISIBLE);
---

<Layout
  title={bill ? `${bill.identifier} — ${bill.title}` : "Bill"}
  description={bill?.title}
>
  {!bill ? (
    <p class="empty-state">No such bill.</p>
  ) : (
    <article data-pagefind-body>
      <p class="page-back">
        <a href={base}>Home</a> · <a href={`${base}bills`}>All bills</a>
      </p>

      <header class="bill-header">
        <span class="bill-id">{bill.identifier}</span>
        <span class="bill-session-tag">Session {bill.session}</span>
        <h1 class="bill-title" data-pagefind-meta={`session:${bill.session}`}>{bill.title}</h1>
      </header>

      <div class={`status-banner ${tone}`}>{bill.current_status}</div>

      <ChamberProgress bill={bill} />

      <div class="bill-layout">
        <div class="bill-main">
          {bill.abstract && (
            <section>
              <h2>Summary</h2>
              <p>{bill.abstract}</p>
            </section>
          )}

          <section>
            <h2>Votes ({bill.votes.length})</h2>
            {sortedVotes.length === 0 ? (
              <p class="empty-state">No roll-call votes recorded yet.</p>
            ) : (
              sortedVotes.map((v, i) => <VoteCard vote={v} defaultOpen={i === 0} />)
            )}
          </section>

          <section>
            <h2>Actions ({bill.actions.length})</h2>
            <ul class="items">
              {bill.actions.map((a) => (
                <li>
                  <span class="num fixed-w">{a.date}</span>
                  {a.chamber && <span class="section-tag">{chamberLabel(a.chamber)}</span>}
                  {a.description}
                </li>
              ))}
            </ul>
          </section>
        </div>

        <aside class="bill-sidebar">
          <h3>Sponsors ({bill.sponsors.length})</h3>
          <ul class="sponsors-list">
            {visiblePrimary.map((s) => (
              <li>
                <strong>{s.name}</strong>
                {s.district && <span class="district"> · District {s.district}</span>}
              </li>
            ))}
          </ul>
          {(hiddenPrimary.length > 0 || coSponsors.length > 0) && (
            <details>
              <summary style="cursor: pointer; color: var(--fg-muted); font-size: var(--text-xs); margin-top: var(--space-2);">
                + {hiddenPrimary.length + coSponsors.length} more
              </summary>
              <ul class="sponsors-list" style="margin-top: var(--space-2);">
                {hiddenPrimary.map((s) => (
                  <li>
                    <strong>{s.name}</strong>
                    {s.district && <span class="district"> · District {s.district}</span>}
                  </li>
                ))}
                {coSponsors.map((s) => (
                  <li>
                    {s.name}
                    {s.district && <span class="district"> · District {s.district}</span>}
                    <span class="district"> · co</span>
                  </li>
                ))}
              </ul>
            </details>
          )}

          {bill.subjects.length > 0 && (
            <>
              <h3>Subjects</h3>
              <div>
                {bill.subjects.map((s) => (
                  <a class="subject-chip" href={`${base}bills?subject=${encodeURIComponent(s)}`}>{s}</a>
                ))}
              </div>
            </>
          )}

          <h3>Last action</h3>
          <p class="meta-line tabular">{bill.last_action_date}</p>

          <h3>Bodies</h3>
          <p>
            {bill.body_ids.map((bid) => {
              const body = getBodyById(bid);
              return body ? <a class="body-pill" href={`${base}body/${bid}`}>{body.name}</a> : null;
            })}
          </p>

          {bill.source_url && (
            <>
              <h3>Source</h3>
              <p><a href={bill.source_url} target="_blank" rel="noopener">View on LRC →</a></p>
            </>
          )}
        </aside>
      </div>
    </article>
  )}
</Layout>
