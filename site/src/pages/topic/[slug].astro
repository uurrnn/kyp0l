---
import Layout from "~/layouts/Layout.astro";
import { billStatusTone, partyAbbrev } from "~/lib/data";
import { getAllTopics, getTopicSummary } from "~/lib/topics";

export function getStaticPaths() {
  return getAllTopics().map((t) => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const summary = getTopicSummary(slug!);
const base = import.meta.env.BASE_URL;

function partyClass(party: string | null): string {
  if (!party) return "";
  const p = party.toLowerCase();
  if (p.startsWith("dem")) return "party-d";
  if (p.startsWith("rep")) return "party-r";
  return "party-i";
}
---

<Layout
  title={summary ? `${summary.subject} — kyp0l` : "Topic"}
  description={summary ? `Bills, sponsors, and committees in Kentucky's ${summary.subject.toLowerCase()} policy area.` : undefined}
>
  {!summary ? (
    <p class="empty-state">No such topic.</p>
  ) : (
    <article data-pagefind-body>
      <p class="page-back">
        <a href={base}>Home</a> · <a href={`${base}topics`}>Topics</a>
      </p>

      <header class="topic-header">
        <h1>{summary.subject}</h1>
        <p class="topic-sub">
          {summary.totalBills.toLocaleString()} bill{summary.totalBills === 1 ? "" : "s"}
          {summary.lastActionDate && <> · last activity {summary.lastActionDate}</>}
        </p>
      </header>

      {summary.totalBills === 0 ? (
        <p class="empty-state">No bills under this topic in the active session yet.</p>
      ) : (
        <>
          <section class="topic-section">
            <h2>Hot in this topic</h2>
            <ul class="hot-list">
              {summary.hotBills.map((b, i) => (
                <li>
                  <a class="hot-row" href={`${base}bill/${b.id}`}>
                    <span class="hot-rank">{i + 1}</span>
                    <span class="hot-id">{b.identifier}</span>
                    <span class="hot-title">{b.title}</span>
                    <span class={`status-badge ${billStatusTone(b)}`}>{b.current_status}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>

          <section class="topic-section">
            <h2>Recent activity</h2>
            <table class="bills-table">
              <thead>
                <tr>
                  <th class="col-date">Date</th>
                  <th class="col-id">Bill</th>
                  <th class="col-title">Action</th>
                </tr>
              </thead>
              <tbody>
                {summary.recentActions.map((r) => (
                  <tr>
                    <td class="col-date">{r.date}</td>
                    <td class="col-id"><a href={`${base}bill/${r.bill.id}`}>{r.bill.identifier}</a></td>
                    <td class="col-title">{r.description}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </section>

          <div class="topic-twocol">
            <section class="topic-section">
              <h2>Top sponsors</h2>
              {summary.topSponsors.length === 0 ? (
                <p class="empty-state">No sponsorship data yet — bills pre-date the upstream identifier capture. Will fill in on the next scrape.</p>
              ) : (
                <ul class="sponsors-list">
                  {summary.topSponsors.map((r) => (
                    <li>
                      <a href={`${base}person/${r.person.id}`}>{r.person.name}</a>
                      {r.person.party && (
                        <span class={`party-chip ${partyClass(r.person.party)}`} style="margin-left: var(--space-2);">{partyAbbrev(r.person.party)}</span>
                      )}
                      <span class="count">{r.count} bill{r.count === 1 ? "" : "s"}</span>
                    </li>
                  ))}
                </ul>
              )}
            </section>

            <section class="topic-section">
              <h2>Related committees</h2>
              {summary.relatedCommittees.length === 0 ? (
                <p class="empty-state">No name-matched committees.</p>
              ) : (
                <ul class="sponsors-list">
                  {summary.relatedCommittees.map((b) => (
                    <li><a class="body-pill" href={`${base}body/${b.id}`}>{b.name}</a></li>
                  ))}
                </ul>
              )}
            </section>
          </div>

          <p style="margin-top: var(--space-5);">
            <a class="compare-cta" href={`${base}bills?subject=${encodeURIComponent(summary.subject)}`}>Browse all {summary.totalBills} bills →</a>
          </p>
        </>
      )}
    </article>
  )}
</Layout>

<style>
  .topic-header {
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border);
  }
  .topic-header h1 {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 600;
    line-height: 1.1;
    margin: 0 0 var(--space-2);
    letter-spacing: -0.02em;
  }
  .topic-sub {
    color: var(--fg-muted);
    font-size: var(--text-sm);
    margin: 0;
  }
  .topic-section {
    margin-bottom: var(--space-6);
  }
  .topic-section h2 {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 600;
    margin: 0 0 var(--space-3);
  }
  .topic-twocol {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }
  @media (max-width: 720px) {
    .topic-twocol { grid-template-columns: 1fr; }
  }
  .sponsors-list .count {
    font-variant-numeric: tabular-nums;
    color: var(--fg-muted);
    font-size: var(--text-xs);
    margin-left: var(--space-2);
  }
</style>
