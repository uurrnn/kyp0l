---
import Layout from "~/layouts/Layout.astro";
import { getBills } from "~/lib/data";
import { BillsFilter } from "~/components/BillsFilter";

const bills = getBills();
const base = import.meta.env.BASE_URL;
const sessions = [...new Set(bills.map((b) => b.session))].sort();
---

<Layout title="Bills — kyp0l" description="Subject-faceted index of Kentucky General Assembly bills.">
  <h1>Bills</h1>
  <p style="color: var(--fg-muted); margin-bottom: var(--space-5);">
    {bills.length.toLocaleString()} bills in the {sessions.join(", ") || "current"} Kentucky General Assembly session.
    Filter by subject, status, or chamber. Selections sync to the URL — sharable and back-button-friendly.
  </p>

  <div data-pagefind-ignore>
    {bills.length === 0 ? (
      <p class="empty-state">
        No bills yet — set <code>OPENSTATES_API_KEY</code> and run
        <code>python -m scrapers --sources openstates</code>.
      </p>
    ) : (
      <BillsFilter client:load base={base} />
    )}
  </div>
</Layout>
