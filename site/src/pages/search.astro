---
import Layout from "~/layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="Search — kyp0l" description="Search agenda items, attachments, bills, and meeting text.">
  <h1>Search</h1>
  <p style="color: var(--fg-muted); margin-bottom: var(--space-5);">
    Full-text search across all indexed agenda content and bill metadata. Try
    <code>budget</code>, <code>zoning</code>, <code>JCPS</code>, or a council member name.
  </p>

  <div id="search"></div>

  <link href={`${base}pagefind/pagefind-ui.css`} rel="stylesheet" />
  <script src={`${base}pagefind/pagefind-ui.js`} is:inline></script>
  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      try {
        // eslint-disable-next-line no-undef
        new PagefindUI({ element: "#search", showSubResults: true });
      } catch (e) {
        document.getElementById("search").innerHTML =
          '<p style="color: var(--fg-muted); font-style: italic">Pagefind index not yet built. Run <code>npm run build</code>.</p>';
      }
    });
  </script>

  <style is:global>
    /* tone Pagefind defaults to match the site palette */
    :root {
      --pagefind-ui-primary: var(--accent);
      --pagefind-ui-text: var(--fg);
      --pagefind-ui-background: var(--bg-card);
      --pagefind-ui-border: var(--border);
      --pagefind-ui-tag: var(--bg-subtle);
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 5px;
      --pagefind-ui-font: var(--font-sans);
    }
    .pagefind-ui__result-title { font-family: var(--font-serif); }
  </style>
</Layout>
