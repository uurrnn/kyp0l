---
import Layout from "~/layouts/Layout.astro";
import { getBodies, getBodyById, getMeetingsByBody, getBillsByBody, formatMeetingDate } from "~/lib/data";

export function getStaticPaths() {
  return getBodies().map((b) => ({ params: { id: b.id } }));
}

const { id } = Astro.params;
const body = getBodyById(id!);
const meetings = body ? getMeetingsByBody(body.id) : [];
const bills = body ? getBillsByBody(body.id) : [];
const base = import.meta.env.BASE_URL;
const MAX_BILLS_PER_BODY = 100;
---

<Layout title={`${body?.name ?? "Body"} — Kentucky + Louisville Politics`}>
  {!body ? (
    <p class="empty-state">No such body.</p>
  ) : (
    <>
      <p><a href={base}>&larr; All bodies</a></p>
      <h1>{body.name}</h1>
      <p class="meta" style="color: var(--fg-muted);">
        Source: <strong>{body.source_type}</strong> ·
        {meetings.length} meetings indexed
      </p>

      {meetings.length > 0 && <h2>Meetings ({meetings.length})</h2>}
      <div data-pagefind-ignore>
        {meetings.map((m) => (
          <a class="meeting-card" href={`${base}meeting/${m.id}`}>
            <div class="date">{formatMeetingDate(m)}</div>
            <div class="title">{m.title}</div>
            <div class="meta">{m.items.length} items · {m.attachments.length} attachments</div>
          </a>
        ))}
        {meetings.length === 0 && bills.length === 0 && (
          <p class="empty-state">Nothing indexed yet for this body.</p>
        )}
      </div>

      {bills.length > 0 && (
        <section style="margin-top: 2rem;">
          <h2>Bills ({bills.length})</h2>
          <div data-pagefind-ignore>
            {bills.slice(0, MAX_BILLS_PER_BODY).map((b) => (
              <a class="meeting-card" href={`${base}bill/${b.id}`}>
                <div class="date">{b.last_action_date}</div>
                <div class="body-name">{b.identifier}</div>
                <div class="title">{b.title}</div>
                <div class="meta">{b.current_status}</div>
              </a>
            ))}
            {bills.length > MAX_BILLS_PER_BODY && (
              <p style="color: var(--fg-muted);">Showing {MAX_BILLS_PER_BODY} of {bills.length}. Use search for more.</p>
            )}
          </div>
        </section>
      )}
    </>
  )}
</Layout>
