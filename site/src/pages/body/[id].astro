---
import Layout from "~/layouts/Layout.astro";
import { getBodies, getBodyById, getMeetingsByBody, formatMeetingDate } from "~/lib/data";

export function getStaticPaths() {
  return getBodies().map((b) => ({ params: { id: b.id } }));
}

const { id } = Astro.params;
const body = getBodyById(id!);
const meetings = body ? getMeetingsByBody(body.id) : [];
const base = import.meta.env.BASE_URL;
---

<Layout title={`${body?.name ?? "Body"} — Louisville Local Politics`}>
  {!body ? (
    <p class="empty-state">No such body.</p>
  ) : (
    <>
      <p><a href={base}>&larr; All bodies</a></p>
      <h1>{body.name}</h1>
      <p class="meta" style="color: var(--fg-muted);">
        Source: <strong>{body.source_type}</strong> ·
        {meetings.length} meetings indexed
      </p>

      <div data-pagefind-ignore>
        {meetings.map((m) => (
          <a class="meeting-card" href={`${base}meeting/${m.id}`}>
            <div class="date">{formatMeetingDate(m)}</div>
            <div class="title">{m.title}</div>
            <div class="meta">{m.items.length} items · {m.attachments.length} attachments</div>
          </a>
        ))}
        {meetings.length === 0 && (
          <p class="empty-state">No meetings indexed yet for this body.</p>
        )}
      </div>
    </>
  )}
</Layout>
